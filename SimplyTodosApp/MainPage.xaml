<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:SimplyTodosApp.ViewModels"
             xmlns:models="clr-namespace:SimplyTodosApp.Models"
             x:DataType="viewmodels:MainViewModel"
             x:Class="SimplyTodosApp.MainPage"
             Shell.NavBarIsVisible="False">

    <AbsoluteLayout>

        <Grid RowDefinitions="75, 50, *"     
            RowSpacing="10"
            Padding="0,20,0,20"
            AbsoluteLayout.LayoutBounds="0, 0, 1, 1"
            AbsoluteLayout.LayoutFlags="All">

            <Grid ColumnDefinitions="Auto,*,50" BackgroundColor="GhostWhite">
                <Label Grid.Column="0" Text="March 16 2026" TextColor="Black" VerticalOptions="Center" HorizontalOptions="Center" FontSize="15" HorizontalTextAlignment="Center" Padding="5"></Label>
                <Label Grid.Column="1" Text="Simply To-dos" TextColor="Black" VerticalOptions="Center" HorizontalOptions="Center" FontSize="20" FontAttributes="Bold" Margin="0,0,40,0"></Label>
                <ImageButton Grid.Column="2" Source="dotnet_bot.png" Margin="0,0,10,0" Clicked="ImageButton_Clicked"></ImageButton>
            </Grid>

            <Grid ColumnDefinitions="*,*" Grid.Row="1">
                <Button x:Name="TodosBtn" BackgroundColor="Gray" Grid.Column="0" Clicked="TodosBtn_Clicked" Text="To-dos" TextColor="White"></Button>
                <Button x:Name="CompletionsBtn" BackgroundColor="GhostWhite" Grid.Column="1" Clicked="CompletionsBtn_Clicked" Text="Completions" TextColor="Black"></Button>
            </Grid>

            <CollectionView Grid.Row="2" ItemsSource="{Binding TasksList}" EmptyView="No task to display...">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Task">
                        <Grid ColumnDefinitions="*,4*,*,*"  HeightRequest="100" Padding="20,10,20,10">
                            <CheckBox Grid.Column="0"  VerticalOptions="Center">

                            </CheckBox>

                            <Grid Grid.Column="1" RowDefinitions="*,3*" VerticalOptions="Center" >
                                <Label Text="{Binding Heading}" Grid.Row="0" />
                                <Label Text="{Binding Description}" Grid.Row="1" />
                            </Grid>

                            <Button Grid.Column="2" Text="E" BackgroundColor="DeepSkyBlue" HorizontalOptions="End"  VerticalOptions="Center" TextColor="White" 
                                  Clicked="Button_Clicked" Margin="0,0,10,0"/>

                            <!-- <ImageButton Grid.Column="3" x:Name="delete" Source="appicon.png" HorizontalOptions="End"  VerticalOptions="Center"></ImageButton> -->
                            <Button Grid.Column="3" Text="D" BackgroundColor="Red" HorizontalOptions="End"  VerticalOptions="Center" TextColor="White" 
                                 Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:MainViewModel}}, Path=DeleteTaskCommand}"
                                 CommandParameter="{Binding .}" />

                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </Grid>

        <Button Text="+"
             FontSize="36"
             FontAttributes="Bold"
             WidthRequest="70"
             HeightRequest="70"
             CornerRadius="35"
             BackgroundColor="DodgerBlue"
             TextColor="White"
             Padding="0"
             AbsoluteLayout.LayoutBounds="0.9, 0.95, 70, 70"
             AbsoluteLayout.LayoutFlags="PositionProportional"
             Command="{Binding AddTaskCommand}" />
    </AbsoluteLayout>


</ContentPage>

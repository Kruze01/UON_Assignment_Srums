<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SimplyTodosApp.MainPage">

    <Grid RowDefinitions="Auto, *" ColumnDefinitions="*">

        <Grid Grid.Row="0" ColumnDefinitions="120,*,50" HeightRequest="50" Margin="0,0,0,10">
            <Label Grid.Column="0" BackgroundColor="Gold" Text="10-March-2026" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" TextColor="Black" />
            <Label Grid.Column="1" BackgroundColor="DeepSkyBlue" Text="Simply To-Dos" HorizontalTextAlignment="Center" VerticalTextAlignment="Center" TextColor="White" />
            <ImageButton Grid.Column="2" BackgroundColor="MidnightBlue" Source="dotnet_bot.png" Aspect="AspectFit" />
        </Grid>


        <VerticalStackLayout Grid.Row="1" Spacing="0">

            <Grid ColumnDefinitions="*,*" HeightRequest="45" BackgroundColor="#F0F0F0">
                <Button x:Name="TodosTabBtn" Grid.Column="0" Text="To-dos" Clicked="TodosTabBtn_Clicked" CornerRadius="0" BackgroundColor="LightGray" TextColor="Black" />
                <Button x:Name="CompletionsTabBtn" Grid.Column="1" Text="Completions" Clicked="CompletionsTabBtn_Clicked" CornerRadius="0" BackgroundColor="White" TextColor="Gray" />
            </Grid>

            <Grid>
                <CollectionView x:Name="ActiveTasksList" IsVisible="True">
                </CollectionView>

                <CollectionView x:Name="CompletedTasksList" IsVisible="False">
                </CollectionView>
            </Grid>

        </VerticalStackLayout>
    </Grid>

</ContentPage>

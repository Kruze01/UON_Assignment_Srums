<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               xmlns:models="clr-namespace:SimplyTodosApp.Models"
               xmlns:converters="clr-namespace:SimplyTodosApp.Converters"
               x:Class="SimplyTodosApp.Views.ReviewTaskPopup"
               x:DataType="models:Task">
    <toolkit:Popup.Resources>
        <converters:PriorityToColorConverter x:Key="PriorityColorConverter" />
    </toolkit:Popup.Resources>

    <Border StrokeThickness="2" 
            Stroke="Black" 
            BackgroundColor="White" 
            Padding="20" 
            WidthRequest="350" 
            HeightRequest="450">

        <Border.StrokeShape>
            <RoundRectangle CornerRadius="15" />
        </Border.StrokeShape>

        <Grid RowDefinitions="Auto, Auto, *, Auto" RowSpacing="10">

            <!-- Scrollable view for task heading-->
            <VerticalStackLayout Grid.Row="0" Spacing="5">
                <ScrollView MaximumHeightRequest="90">
                <Label Text="{Binding Heading}" 
                       FontSize="22" 
                       FontAttributes="Bold" 
                       TextColor="Black" 
                       HorizontalOptions="Center" 
                       HorizontalTextAlignment="Center" />
                </ScrollView>
                <BoxView HeightRequest="1" 
                         Color="LightGray" 
                         HorizontalOptions="Fill" />
            </VerticalStackLayout>

            <!-- For task description -->
            <HorizontalStackLayout Grid.Row="1" Spacing="5">
                <Label Text="Priority:" 
                       FontSize="14" 
                       TextColor="Gray" />
                <Label Text="{Binding Priority}" 
                       FontSize="14" 
                       FontAttributes="Bold" 
                       TextColor="{Binding Priority, Converter={StaticResource PriorityColorConverter}}" />
            </HorizontalStackLayout>

            <!-- Scrollable view for task description-->
            <Grid Grid.Row="2" RowDefinitions="Auto, *">
                <Label Grid.Row="0" 
                       Text="Description:" 
                       FontSize="14" 
                       TextColor="Gray" 
                       Margin="0,0,0,5"/>

                <ScrollView Grid.Row="1" VerticalScrollBarVisibility="Always">
                    <Label Text="{Binding Description}" 
                           FontSize="16" 
                           TextColor="Black" 
                           LineBreakMode="WordWrap" />
                </ScrollView>
            </Grid>

            <!-- Close button -->
            <Button Grid.Row="3" 
                    Text="Close" 
                    WidthRequest="100" 
                    Clicked="OnCloseClicked" 
                    BackgroundColor="DodgerBlue" 
                    TextColor="White" 
                    Margin="0,10,0,0" />
        </Grid>
    </Border>
</toolkit:Popup>
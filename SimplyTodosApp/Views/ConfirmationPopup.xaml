<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               x:Class="SimplyTodosApp.Views.ConfirmationPopup"
               x:TypeArguments="x:Boolean"
               CanBeDismissedByTappingOutsideOfPopup="False">

    <Border StrokeThickness="2" Stroke="Red" BackgroundColor="White" Padding="20" WidthRequest="350">
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="15" />
        </Border.StrokeShape>

        <VerticalStackLayout Spacing="20">
            <Label x:Name="PopupHeading"
                   FontSize="25" 
                   FontAttributes="Bold" 
                   HorizontalOptions="Center" 
                   HorizontalTextAlignment="Center" 
                   TextColor="Red"
                   Margin="0,0,0,20"/>

            <Label x:Name="PopupBody"
                   HorizontalTextAlignment="Center" 
                   TextColor="Black"/>

            <Label Text="This action cannot be undone"
                   TextColor="Red"
                   FontAttributes="Bold" 
                   TextDecorations="Underline"
                   HorizontalTextAlignment="Center" />

            <HorizontalStackLayout Spacing="35" HorizontalOptions="Center" Margin="0,20,0,0">
                <Button Text="Cancel" Clicked="OnCancelClicked" BackgroundColor="LightGray" TextColor="Black" FontAttributes="Bold" WidthRequest="100" />
                <Button Text="Remove" Clicked="OnConfirmClicked" BackgroundColor="Red" TextColor="White" FontAttributes="Bold" WidthRequest="100" />
            </HorizontalStackLayout>
        </VerticalStackLayout>
    </Border>
</toolkit:Popup>